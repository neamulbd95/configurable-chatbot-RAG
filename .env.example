# Copy to .env and adjust. All values are also overridable via real env vars,
# which is what a container/microservice deployment should use (NFR-1.8).

APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Required header (X-Admin-Api-Key) for /admin/* endpoints (vector store
# reset, ingestion trigger/status). Leave unset only for local dev.
# ADMIN_API_KEY=

# --- Source RDBMS (FR-1.1, FR-1.6) ---
# SOURCE_DB_ENGINE selects the SQLAlchemy dialect: postgresql | mysql | mssql | oracle
SOURCE_DB_ENGINE=postgresql
SOURCE_DB_HOST=localhost
SOURCE_DB_PORT=5432
SOURCE_DB_USER=postgres
SOURCE_DB_PASSWORD=postgres
SOURCE_DB_NAME=app
# SOURCE_DB_DRIVER_OVERRIDE=
# Default schema/database-owner for tables that don't set their own
# `schema:` in tables.yaml (e.g. Postgres "public", SQL Server "dbo", or a
# custom schema like "esg"). This is an env var rather than a tables.yaml
# field because which schema holds your tables is a per-environment fact —
# it commonly differs machine to machine — not something to hardcode into a
# config file that's typically shared/committed. Per-table `schema:` in
# tables.yaml still overrides this when set.
# SOURCE_DB_SCHEMA=
# Seconds to wait for a source DB connection before giving up (used by
# ingestion and GET /admin/source-db/status) — without this, an
# unreachable/filtered host can hang far longer than the OS's own TCP
# timeout.
SOURCE_DB_CONNECT_TIMEOUT_SECONDS=10

TABLES_CONFIG_PATH=config/tables.yaml

# --- Vector store (FR-1.7) — independent of the source RDBMS above ---
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=5433
VECTOR_DB_USER=postgres
VECTOR_DB_PASSWORD=postgres
VECTOR_DB_NAME=vectorstore
VECTOR_TABLE_NAME=chunks

# --- Chunking (FR-2.1) ---
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# --- Retrieval (FR-3.1, FR-3.2) ---
RETRIEVAL_TOP_K=5
RETRIEVAL_SIMILARITY_THRESHOLD=0.65

# --- Hybrid retrieval & reranking (FR-6.6-6.8) ---
# 0 = pure vector search (default). >0 blends in Postgres full-text ranking.
RETRIEVAL_KEYWORD_WEIGHT=0.0
# Requires `pip install .[rerank]` when true.
RERANK_ENABLED=false
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Conversational context (FR-6.11-6.13) ---
HISTORY_MAX_MESSAGES=6
HISTORY_MAX_CHARS=4000

# --- Providers (FR-5.1-5.3): ollama | azure_openai ---
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
CHAT_PROVIDER=ollama
CHAT_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434

# --- Azure OpenAI (only required when a provider above is azure_openai) ---
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_CHAT_DEPLOYMENT=
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
